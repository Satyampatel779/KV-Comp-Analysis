# Copy to .env and fill in. The API loads this automatically (python-dotenv).
# Use the SAME MongoDB Atlas URI the CLI ranking script already uses.
MONGODB_URI=
MONGODB_DB=kv_comp_analysis

# API server
API_HOST=0.0.0.0
API_PORT=8000

# Optional: if set, all endpoints require an `x-api-key` header matching this value.
# Leave blank for local development.
API_KEY=

# --- Streamlit UI ---
# Where the UI reaches the FastAPI service (docker-compose overrides to http://api:8000).
API_BASE_URL=http://localhost:8000

# --- LLM (Groq, OpenAI-compatible) — enables POST /ask + the UI assistant ---
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1

# --- Optional: Google Maps (inline Street View Static photos) ---
# Leave blank to use the no-key aerial image + clickable Maps/Street View links.
GOOGLE_MAPS_API_KEY=

